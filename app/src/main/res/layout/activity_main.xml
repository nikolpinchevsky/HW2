<?xml version="1.0" encoding="utf-8"?>
<LinearLayout  xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_color"
    >

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/default_margin"
        android:layout_gravity="end"
        >

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/mainImgHeart0"
            android:layout_width="@dimen/heart_dimens"
            android:layout_height="@dimen/heart_dimens"
            android:layout_marginEnd="@dimen/heart_margin"
            app:srcCompat="@drawable/heart"
         />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/mainImgHeart1"
            android:layout_width="@dimen/heart_dimens"
            android:layout_height="@dimen/heart_dimens"
            android:layout_marginStart="@dimen/heart_margin"
            android:layout_marginEnd="@dimen/heart_margin"
            app:srcCompat="@drawable/heart"
         />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/mainImgHeart2"
            android:layout_width="@dimen/heart_dimens"
            android:layout_height="@dimen/heart_dimens"
            android:layout_marginStart="@dimen/heart_margin"
            android:visibility="visible"

            app:srcCompat="@drawable/heart"
         />
    </LinearLayout>

    <GridLayout
        android:id="@+id/game_board"
        android:layout_height="0dp"
        android:layout_width="match_parent"
        android:layout_weight="8"
        android:columnCount="3"
        android:rowCount="6">

        <com.google.android.material.imageview.ShapeableImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_gravity="fill"
            app:srcCompat="@drawable/ice" />

        <com.google.android.material.imageview.ShapeableImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_gravity="fill"
            app:srcCompat="@drawable/ice" />

        <com.google.android.material.imageview.ShapeableImageView
            android:layout_width="0dp"
