    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="@dimen/marginBottom">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/mainFabLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="true"
            app:icon="@drawable/arrow"
            android:layout_alignParentBottom="true"
            android:layout_alignParentStart="true"
            app:srcCompat="@drawable/arrow"
            android:layout_marginStart="@dimen/button_margin"
            android:layout_marginBottom="@dimen/button_down_margin"
            android:rotationY="180"
            android:backgroundTint="@color/button_color"
            android:contentDescription="@string/arrow_left_description"
            />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/mainFabRight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="true"
            app:icon="@drawable/arrow"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            app:srcCompat="@drawable/arrow"
            android:layout_marginEnd="@dimen/button_margin"
            android:layout_marginBottom="@dimen/button_down_margin"
            android:backgroundTint="@color/button_color"
            android:contentDescription="@string/arrow_right_description"
            />
    </RelativeLayout>

